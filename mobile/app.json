{
  "expo": {
    "name": "IQritsa",
    "slug": "iqritsa-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-1024.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050510"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.iqritsa.app"
    },
    "android": {
      "package": "com.iqritsa.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050510"
      }
    },
    "extra": {
      "webAppUrl": "https://your-vercel-domain.vercel.app"
    }
  }
}
